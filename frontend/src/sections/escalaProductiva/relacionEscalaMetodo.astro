---
import graficaData from '../../data/B4/bloque_4_metodo_vs_escala_grafica.json'
import B4StackedMetodoEscala from '../../components/charts/B4StackedMetodoEscala'
import AnimatedCounter from '../../components/AnimatedCounter'

const totalRegistros = graficaData.metadata.total_registros
---

<section class="b4e-section w-[80%] mx-auto border border-white/20">
  <div class="b4e-inner">
    <!-- Section header -->
    <div class="b4e-header">
      <span class="b4e-badge">BLOCK 04 · PRODUCTION SCALE</span>
      <h2 class="b4e-title">Extraction Method vs. Production Scale</h2>
      <p class="b4e-subtitle">
        Absolute distribution of <AnimatedCounter
          client:only="react"
          value={totalRegistros}
          duration={1800}
          className="b4e-num"
        /> records by extraction method and production scale. Records with unknown scale are excluded
        to show the actual relationship between mining type and operation size.
      </p>
    </div>

    <!-- Chart container -->
    <div class="b4e-chart-wrapper">
      <B4StackedMetodoEscala data={graficaData} client:only="react" />
    </div>

    <!-- Contextual insight -->
    <div class="b4e-insight">
      <span class="b4e-insight__icon">🔍</span>
      <p class="b4e-insight__text">
        <strong>Underground</strong> mining dominates both at small scale (<AnimatedCounter
          client:only="react"
          value={167}
          duration={1400}
          className="b4e-num"
        /> sites) and large scale (<AnimatedCounter
          client:only="react"
          value={143}
          duration={1400}
          className="b4e-num"
        />), reflecting its operational versatility in Peru. In contrast, <strong>surface</strong> mining
        has the highest proportion of records
        <strong>with no scale data</strong> (<AnimatedCounter
          client:only="react"
          value={25.9}
          decimals={1}
          suffix="%"
          duration={1400}
          className="b4e-num"
        />), suggesting a particularly acute information gap for open-pit operations.
      </p>
    </div>
  </div>
</section>

<style>
  .b4e-section {
    padding: 80px 0 60px;
    background: var(--bg-primary);
  }

  .b4e-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Header */
  .b4e-header {
    margin-bottom: 40px;
  }

  .b4e-badge {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--accent-lime);
    text-transform: uppercase;
    margin-bottom: 12px;
    padding: 4px 14px;
    border-radius: 999px;
    background: rgba(193, 214, 91, 0.08);
    border: 1px solid rgba(193, 214, 91, 0.15);
  }

  .b4e-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }

  .b4e-subtitle {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 680px;
    margin: 0;
  }

  .b4e-subtitle strong {
    color: var(--accent-lime-light);
  }

  .b4e-subtitle :global(.b4e-num),
  .b4e-insight__text :global(.b4e-num) {
    color: var(--accent-lime-light);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.3px;
  }

  /* Chart wrapper */
  .b4e-chart-wrapper {
    padding: 24px;
    border-radius: 16px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(12px);
    margin-bottom: 28px;
  }

  /* Insight */
  .b4e-insight {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px 24px;
    border-radius: 12px;
    background: rgba(193, 214, 91, 0.04);
    border: 1px solid rgba(193, 214, 91, 0.12);
  }

  .b4e-insight__icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .b4e-insight__text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .b4e-insight__text strong {
    color: var(--accent-lime-light);
  }
</style>
