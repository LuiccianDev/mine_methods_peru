---
import estadoData from '../../data/B5/bloque_5_estado_desarrollo_vs_metodo.json'
import B5BarDesarrolloMetodo from '../../components/charts/B5BarDesarrolloMetodo'
import AnimatedCounter from '../../components/AnimatedCounter'

const totalRegistros = estadoData.metadata.total_registros
---

<section class="b5a-section w-[80%] mx-auto border border-white/20">
  <div class="b5a-inner">
    <!-- Section header -->
    <div class="b5a-header">
      <span class="b5a-badge">BLOCK 05 · LIFE CYCLE</span>
      <h2 class="b5a-title">Absolute Distribution: Development Status vs. Method</h2>
      <p class="b5a-subtitle">
        Absolute frequency of <AnimatedCounter
          client:only="react"
          value={totalRegistros}
          duration={1800}
          className="b5a-num"
        /> records classified by development status and extraction method. This view complements the percentage
        distribution, revealing the actual weight of each category in terms of volume.
      </p>
    </div>

    <!-- Chart container -->
    <div class="b5a-chart-wrapper">
      <B5BarDesarrolloMetodo data={estadoData} client:only="react" />
    </div>

    <!-- Contextual insight -->
    <div class="b5a-insight">
      <span class="b5a-insight__icon">🔍</span>
      <p class="b5a-insight__text">
        <strong>Past producers</strong> concentrate the highest number of underground mines (<AnimatedCounter
          client:only="react"
          value={142}
          duration={1400}
          className="b5a-num"
        />), while <strong>occurrences</strong> dominate the total volume with <AnimatedCounter
          client:only="react"
          value={1258}
          duration={1600}
          className="b5a-num"
        /> records — of which <AnimatedCounter
          client:only="react"
          value={1072}
          duration={1600}
          className="b5a-num"
        /> have an unknown method. <strong>Active producers</strong> show the most balanced distribution
        among known methods, with <AnimatedCounter
          client:only="react"
          value={122}
          duration={1400}
          className="b5a-num"
        /> underground,
        <AnimatedCounter client:only="react" value={53} duration={1400} className="b5a-num" /> surface,
        and <AnimatedCounter client:only="react" value={19} duration={1400} className="b5a-num" /> mixed.
      </p>
    </div>
  </div>
</section>

<style>
  .b5a-section {
    padding: 80px 0 60px;
    background: var(--bg-primary);
  }

  .b5a-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Header */
  .b5a-header {
    margin-bottom: 40px;
  }

  .b5a-badge {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--accent-lime);
    text-transform: uppercase;
    margin-bottom: 12px;
    padding: 4px 14px;
    border-radius: 999px;
    background: rgba(193, 214, 91, 0.08);
    border: 1px solid rgba(193, 214, 91, 0.15);
  }

  .b5a-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }

  .b5a-subtitle {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 680px;
    margin: 0;
  }

  .b5a-subtitle strong {
    color: var(--accent-lime-light);
  }

  .b5a-subtitle :global(.b5a-num),
  .b5a-insight__text :global(.b5a-num) {
    color: var(--accent-lime-light);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.3px;
  }

  /* Chart wrapper */
  .b5a-chart-wrapper {
    padding: 24px;
    border-radius: 16px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(12px);
    margin-bottom: 28px;
  }

  /* Insight */
  .b5a-insight {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px 24px;
    border-radius: 12px;
    background: rgba(193, 214, 91, 0.04);
    border: 1px solid rgba(193, 214, 91, 0.12);
  }

  .b5a-insight__icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .b5a-insight__text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .b5a-insight__text strong {
    color: var(--accent-lime-light);
  }
</style>
