---
import Image from 'astro/components/Image.astro'
import imagen_hero from '../assets/background_site.png'
---

<section class="relative min-h-[85vh] flex flex-col">
  <!-- Content card — centered, NOT full-width -->
  <div
    class="relative z-10 flex-1 flex items-center justify-center w-[80%] mx-auto border-l border-r  border-white/20 bg-black"
  >
    <div class="w-full relative">
      <div
        class="absolute top-1/2 left-1/2 w-full max-w-175 -translate-x-1/2 -translate-y-full px-6 z-20 flex flex-col items-center text-center"
      >
        <div
          class="mb-5 inline-flex items-center rounded-full border border-white/10 bg-white/5 py-1.5 px-4"
        >
          <span class="text-[0.625rem] font-semibold uppercase tracking-[1.5px] text-white/55"
            >HERRAMIENTA PODEROSA DE ANÁLISIS</span
          >
        </div>
        <h1 class="text-3xl pb-2">Piensa más profundo. Sueña imposible.</h1>
        <p class="text-sm pb-4">
          MineríaPE te ayuda a crear, optimizar y organizar análisis poderosos<br />
          de sitios mineros en el Perú.
        </p>
      </div>
      <!-- data.png fills only the bottom portion -->
    </div>
    <div class="absolute inset-0 flex items-end justify-center pointer-events-none">
      <Image
        src={imagen_hero}
        alt="Mapa minero del Perú"
        loading="eager"
        class="w-full h-auto object-contain"
      />
    </div>
  </div>
</section>
