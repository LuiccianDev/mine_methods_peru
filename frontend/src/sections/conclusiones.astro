---
const hallazgos = [
  {
    num: '01',
    title: 'Dominant Method',
    text: "Underground mining is the predominant method among sites with a registered method, reflecting Peru's Andean mining tradition centered on polymetallic veins. However, there is a significant information gap that must be considered.",
  },
  {
    num: '02',
    title: 'The Mineral Determines the Method',
    text: 'A clear geological relationship exists — vein minerals (Zn, Pb, Ag, Au) are associated with Underground, while Copper (Cu) is associated with Surface, consistent with porphyry deposits.',
  },
  {
    num: '03',
    title: 'Robust Territorial Patterns',
    text: 'The central Andes (Junín, Pasco, Ancash) are predominantly underground, while the southern Andes (Arequipa, Cusco, Apurímac) show greater method diversification, including more open-pit operations.',
  },
  {
    num: '04',
    title: 'Production Scale Matters',
    text: 'Surface operations tend to be larger in scale (economies of scale), while Underground is associated with small and medium operations (greater selectivity).',
  },
  {
    num: '05',
    title: 'Maturity Reduces Ambiguity',
    text: 'Producers have a defined method; Occurrences and Prospects have a higher proportion of Unknown, reflecting their evaluation stage — not simply missing data.',
  },
]
---

<section
  id="synthesis"
  class="concl-section w-[80%] mx-auto border-l border-r border-white/20 border-t border-b"
>
  <div class="concl-inner">
    <!-- Header -->
    <div class="concl-header">
      <span class="concl-badge">CONCLUSIONS · SYNTHESIS</span>
      <h2 class="concl-title">Answer to the Main Question</h2>
      <p class="concl-subtitle">
        Which extraction method dominates in Peru according to mineral type and region, and how does
        it relate to <strong>production scale</strong> and the
        <strong>development status</strong> of the project?
      </p>
    </div>

    <!-- Hallazgos grid -->
    <div class="concl-grid">
      {
        hallazgos.map((h) => (
          <div class="concl-card">
            <span class="concl-card__num">{h.num}</span>
            <h3 class="concl-card__title">{h.title}</h3>
            <p class="concl-card__text">{h.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .concl-section {
    padding: 80px 0 60px;
    background: var(--bg-primary);
  }

  .concl-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Header ── */
  .concl-header {
    margin-bottom: 40px;
  }

  .concl-badge {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--accent-lime);
    text-transform: uppercase;
    margin-bottom: 12px;
    padding: 4px 14px;
    border-radius: 999px;
    background: rgba(193, 214, 91, 0.08);
    border: 1px solid rgba(193, 214, 91, 0.15);
  }

  .concl-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }

  .concl-subtitle {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 680px;
    margin: 0;
  }

  .concl-subtitle strong {
    color: var(--accent-lime-light);
  }

  /* ── Hallazgos grid ── */
  .concl-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .concl-card {
    position: relative;
    padding: 24px 28px 24px 80px;
    border-radius: 16px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(12px);
    transition: border-color 0.25s ease;
  }

  .concl-card:hover {
    border-color: rgba(193, 214, 91, 0.2);
  }

  .concl-card__num {
    position: absolute;
    left: 24px;
    top: 24px;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--accent-lime);
    opacity: 0.5;
    line-height: 1;
  }

  .concl-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 8px;
  }

  .concl-card__text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (min-width: 768px) {
    .concl-grid {
      grid-template-columns: 1fr 1fr;
    }

    .concl-grid > :first-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .concl-title {
      font-size: 1.5rem;
    }

    .concl-card {
      padding: 20px 20px 20px 64px;
    }

    .concl-card__num {
      left: 20px;
    }
  }
</style>
