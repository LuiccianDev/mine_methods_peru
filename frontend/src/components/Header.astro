---

<header class="header-wrap">
  <nav class="nav-container">
    <div class="logo">
      <a href="/" class="logo-link">Luiccian</a>
    </div>
    <div class="nav-links">
      <a href="#methodology" class="nav-link">Methodology</a>
      <a href="#charts" class="nav-link">Analysis</a>
      <a href="#map" class="nav-link">Map</a>
    </div>
    <div class="nav-actions">
      <a href="#synthesis" class="btn-outline">View Findings</a>
      <a
        href="https://github.com/LuiccianDev/mine_methods_peru/blob/main/analysis/script/analisis_mineria_peru.ipynb"
        class="btn-solid">NooteBook</a
      >
    </div>
  </nav>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const logoLink = document.querySelector('.logo-link')
    if (logoLink) {
      logoLink.addEventListener('click', (e) => {
        e.preventDefault()
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })
    }

    const navLinks = document.querySelectorAll('.nav-link, .btn-outline, .btn-solid')

    navLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href') ?? ''
        if (!href.startsWith('#')) return
        e.preventDefault()
        const targetId = href.slice(1)
        if (!targetId) return

        const targetElement = document.getElementById(targetId)
        if (!targetElement) return

        const headerElement = document.querySelector('.header-wrap')
        const headerHeight = headerElement ? headerElement.offsetHeight : 0
        const targetPosition = targetElement.getBoundingClientRect().top + window.scrollY
        const offsetPosition = targetPosition - headerHeight

        window.scrollTo({
          top: offsetPosition,
          behavior: 'smooth',
        })
      })
    })
  })
</script>

<style>
  /* ── Header wrapper ────────────────────────────────────── */
  .header-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    flex-direction: column;
    background: #000000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  /* ── Navigation ────────────────────────────────────────── */
  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 85%;
    margin: 0 auto;
    padding: 16px 24px;
  }

  @media (min-width: 768px) {
    .nav-container {
      padding: 16px 32px;
    }
  }

  @media (min-width: 1024px) {
    .nav-container {
      padding: 16px 48px;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    color: #ffffff;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
  }

  @media (min-width: 768px) {
    .logo {
      font-size: 0.875rem;
    }
  }

  .nav-links {
    display: none;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
      gap: 32px;
    }
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease;
    cursor: pointer;
  }

  .nav-link:hover {
    color: #ffffff;
  }

  .nav-link:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .nav-actions {
    display: flex;
    gap: 8px;
  }

  .btn-outline {
    display: none;
    padding: 6px 16px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.7rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  @media (min-width: 640px) {
    .btn-outline {
      display: block;
      font-size: 0.75rem;
    }
  }

  .btn-outline:hover {
    border-color: rgba(255, 255, 255, 0.45);
    color: #ffffff;
  }

  .btn-outline:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: 4px;
  }

  .btn-solid {
    padding: 6px 12px;
    border-radius: 999px;
    background: #ffffff;
    color: #000000;
    font-size: 0.7rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  @media (min-width: 640px) {
    .btn-solid {
      padding: 6px 16px;
      font-size: 0.75rem;
    }
  }

  .btn-solid:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  .btn-solid:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: 4px;
  }
</style>
